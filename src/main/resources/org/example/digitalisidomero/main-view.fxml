<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.digitalisidomero.ui.MainController"
            stylesheets="@styles.css"
            minWidth="900" minHeight="600">

    <!-- BAL OLDALI SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="0" minWidth="150" maxWidth="150">

            <!-- Logo -->
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="5">
                <padding>
                    <Insets top="20" bottom="15"/>
                </padding>
                <Label text="⏱️" styleClass="sidebar-logo"/>
                <Label text="Time" styleClass="sidebar-title"/>
                <Label text="Tracker" styleClass="sidebar-subtitle"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- Navigáció -->
            <VBox spacing="8" VBox.vgrow="NEVER">
                <padding>
                    <Insets top="25" left="12" right="12" bottom="12"/>
                </padding>

                <Button fx:id="navHomeButton" onAction="#showHomePage" styleClass="nav-button, nav-button-active" maxWidth="Infinity">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="🏠" styleClass="nav-button-icon"/>
                            <Label text="Főoldal" styleClass="nav-button-text"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="navStatsButton" onAction="#showStatisticsPage" styleClass="nav-button" maxWidth="Infinity">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="📊" styleClass="nav-button-icon"/>
                            <Label text="Statisztika" styleClass="nav-button-text"/>
                        </VBox>
                    </graphic>
                </Button>

                <Button fx:id="navStopperButton" onAction="#showStopperPage" styleClass="nav-button" maxWidth="Infinity">
                    <graphic>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="⏱️" styleClass="nav-button-icon"/>
                            <Label text="Stopper" styleClass="nav-button-text"/>
                        </VBox>
                    </graphic>
                </Button>


            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Állapot -->
            <VBox alignment="CENTER">
                <padding>
                    <Insets top="20" bottom="25" left="15" right="15"/>
                </padding>
                <Label fx:id="statusLabel" text="Leállítva" styleClass="status-label, status-stopped"/>
            </VBox>

        </VBox>
    </left>

    <!-- TARTALOM TERÜLET -->
    <center>
        <StackPane styleClass="content-area">

            <!-- FŐOLDAL -->
            <ScrollPane fx:id="homeViewScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="homeView" spacing="20" styleClass="responsive-container">
                    <padding>
                        <Insets top="30" bottom="30" left="40" right="40"/>
                    </padding>

                    <!-- Fejléc -->
                    <VBox spacing="8" styleClass="card">
                        <padding>
                            <Insets top="25" bottom="25" left="30" right="30"/>
                        </padding>
                        <Label text="Digitális Időmérő" styleClass="card-header"/>
                        <Label text="Kövesse nyomon digitális eszközhasználatát" styleClass="card-subtitle"/>
                    </VBox>

                    <!-- Kategória választás -->
                    <VBox spacing="12" styleClass="card">
                        <padding>
                            <Insets top="25" bottom="25" left="30" right="30"/>
                        </padding>
                        <Label text="📂 Naplózási kategória" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Separator/>
                        <Label text="Válaszd ki, hogy most milyen tevékenységet végzel. A naplózás eszerint menti az időt."
                               style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;"/>

                        <HBox spacing="12" alignment="CENTER">
                            <ToggleButton fx:id="workCategoryToggle" text="💼 Munka" styleClass="category-toggle, category-work"
                                          prefWidth="160" prefHeight="50"/>
                            <ToggleButton fx:id="studyCategoryToggle" text="📚 Tanulás" styleClass="category-toggle, category-study"
                                          prefWidth="160" prefHeight="50"/>
                            <ToggleButton fx:id="entertainmentCategoryToggle" text="🎮 Szórakozás" styleClass="category-toggle, category-entertainment"
                                          prefWidth="160" prefHeight="50"/>
                        </HBox>
                    </VBox>

                    <!-- Vezérlők -->
                    <HBox spacing="15" alignment="CENTER" styleClass="card">
                        <padding>
                            <Insets top="25" bottom="25" left="30" right="30"/>
                        </padding>
                        <Button fx:id="startButton" text="▶  Indítás" onAction="#handleStart"
                                styleClass="control-button, btn-start" minWidth="140" prefHeight="50"/>
                        <Button fx:id="pauseButton" text="⏸  Szünet" onAction="#handlePause"
                                styleClass="control-button, btn-pause" minWidth="140" prefHeight="50" disable="true"/>
                        <Button fx:id="stopButton" text="⏹  Leállítás" onAction="#handleStop"
                                styleClass="control-button, btn-stop" minWidth="140" prefHeight="50" disable="true"/>
                    </HBox>

                    <!-- Jelenlegi alkalmazás -->
                    <VBox spacing="15" styleClass="card">
                        <padding>
                            <Insets top="25" bottom="25" left="30" right="30"/>
                        </padding>
                        <Label text="🖥️ Jelenlegi alkalmazás" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Separator/>

                        <VBox spacing="8">
                            <Label fx:id="currentAppLabel" text="Nincs aktív követés" styleClass="current-app-label"/>
                            <Label fx:id="currentAppCategoryLabel" text="" styleClass="current-app-category"/>
                        </VBox>

                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="session-time-container">
                            <padding>
                                <Insets top="10"/>
                            </padding>
                            <Label text="⏱️" style="-fx-font-size: 32px;"/>
                            <VBox spacing="4">
                                <Label text="Session idő" styleClass="session-time-label"/>
                                <Label fx:id="currentSessionTimeLabel" text="00:00:00" styleClass="session-time-value"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Mai statisztika -->
                    <GridPane hgap="15" vgap="15">
                        <VBox spacing="10" alignment="CENTER" styleClass="stat-card, stat-card-blue"
                              GridPane.columnIndex="0" minHeight="140">
                            <padding>
                                <Insets top="20" bottom="20" left="15" right="15"/>
                            </padding>
                            <Label text="📊" styleClass="stat-card-icon"/>
                            <Label text="ÖSSZES IDŐ MA" styleClass="stat-card-label" style="-fx-text-fill: #1e40af;"/>
                            <Label fx:id="todayTotalLabel" text="0ó 0p" styleClass="stat-card-value" style="-fx-text-fill: #1e3a8a;"/>
                        </VBox>

                        <VBox spacing="10" alignment="CENTER" styleClass="stat-card, stat-card-green"
                              GridPane.columnIndex="1" minHeight="140">
                            <padding>
                                <Insets top="20" bottom="20" left="15" right="15"/>
                            </padding>
                            <Label text="💼" styleClass="stat-card-icon"/>
                            <Label text="MUNKA" styleClass="stat-card-label" style="-fx-text-fill: #15803d;"/>
                            <Label fx:id="todayWorkLabel" text="0ó 0p" styleClass="stat-card-value" style="-fx-text-fill: #166534;"/>
                        </VBox>

                        <VBox spacing="10" alignment="CENTER" styleClass="stat-card, stat-card-red"
                              GridPane.columnIndex="2" minHeight="140">
                            <padding>
                                <Insets top="20" bottom="20" left="15" right="15"/>
                            </padding>
                            <Label text="🎮" styleClass="stat-card-icon"/>
                            <Label text="SZÓRAKOZÁS" styleClass="stat-card-label" style="-fx-text-fill: #b91c1c;"/>
                            <Label fx:id="todayEntertainmentLabel" text="0ó 0p" styleClass="stat-card-value" style="-fx-text-fill: #991b1b;"/>
                        </VBox>

                        <columnConstraints>
                            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" minWidth="180"/>
                            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" minWidth="180"/>
                            <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS" minWidth="180"/>
                        </columnConstraints>
                    </GridPane>

                </VBox>
            </ScrollPane>

            <!-- STATISZTIKA VIEW -->
            <VBox fx:id="statisticsView" visible="false" managed="false" style="-fx-background-color: transparent;"/>

            <!-- STOPPER VIEW -->
            <VBox fx:id="stopperView" visible="false" managed="false" style="-fx-background-color: transparent;"/>


        </StackPane>
    </center>

</BorderPane>